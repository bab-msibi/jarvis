OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
AGENT_GATEWAY_URL=http://127.0.0.1:1878

# Optional remote JARVIS nodes reachable over LAN/VPN/private tunnel.
# Keep URLs private; do not expose a node directly to the public internet without auth.
# Example:
# JARVIS_REMOTE_NODES=[{"id":"studio-pc","name":"Studio PC","role":"remote","baseUrl":"http://192.168.1.50:3000","description":"Remote workstation","enabled":true,"requiresApprovalForActions":true,"tags":["lan","windows"]}]
JARVIS_REMOTE_NODES=

OBSIDIAN_VAULT_PATH=

# JARVIS persistent storage.
# Default: ./.jarvis-data/database.json
# For an external SSD later, use one of these:
# JARVIS_DATA_DIR=/Volumes/ExternalSSD/JARVIS
# DATABASE_URL=file:/Volumes/ExternalSSD/JARVIS/database.json
JARVIS_DATA_DIR=
DATABASE_URL=
